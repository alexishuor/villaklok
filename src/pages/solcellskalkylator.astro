---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Calculator from '../components/Calculator.astro';
import InfoSection from '../components/InfoSection.astro';
import AnalysisSection from '../components/AnalysisSection.astro';
import FAQSection from '../components/FAQSection.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="Solcellskalkylator 2026 | Beräkna solceller tak, pris & ROI för din villa"
  description="Gratis solcellskalkylator för villa. Beräkna solceller tak — pris, återbetalningstid och besparing på 30 sekunder. Uppdaterad med Grön Teknik-avdraget 2026."
>
  <Header page="calculator" />
  <main>
    <Hero />
    <Calculator />
    <InfoSection />
    <AnalysisSection />
    <FAQSection />
    <FinalCTA />
  </main>
  <Footer />
</BaseLayout>
