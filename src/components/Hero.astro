---
---
<section class="relative overflow-hidden bg-hero-gradient min-h-[480px] flex items-center">

  <!-- AMBIENT GLOW ORBS -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute top-[-80px] right-[-60px] w-[420px] h-[420px] rounded-full"
         style="background: radial-gradient(circle, rgba(245,158,11,0.10) 0%, transparent 70%)">
    </div>
    <div class="absolute bottom-[-60px] left-[10%] w-[300px] h-[300px] rounded-full"
         style="background: radial-gradient(circle, rgba(16,185,129,0.07) 0%, transparent 70%)">
    </div>
    <!-- Grid pattern overlay -->
    <div class="absolute inset-0 opacity-[0.03]"
         style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 60px 60px;">
    </div>
  </div>

  <!-- DECORATIVE SUN (right side, desktop) -->
  <div class="pointer-events-none absolute right-8 top-1/2 -translate-y-1/2 opacity-[0.06] hidden lg:block" aria-hidden="true">
    <svg viewBox="0 0 300 300" class="w-[320px] h-[320px] sun-spin origin-center text-solar-amber">
      <circle cx="150" cy="150" r="55" fill="currentColor"/>
      <g stroke="currentColor" stroke-width="8" stroke-linecap="round">
        <line x1="150" y1="20"  x2="150" y2="65"  />
        <line x1="150" y1="235" x2="150" y2="280" />
        <line x1="20"  y1="150" x2="65"  y2="150" />
        <line x1="235" y1="150" x2="280" y2="150" />
        <line x1="58"  y1="58"  x2="90"  y2="90"  />
        <line x1="210" y1="210" x2="242" y2="242" />
        <line x1="242" y1="58"  x2="210" y2="90"  />
        <line x1="90"  y1="210" x2="58"  y2="242" />
      </g>
    </svg>
  </div>

  <div class="relative z-10 max-w-6xl mx-auto px-5 py-16 md:py-20 lg:py-24">
    <div class="max-w-[720px]">

      <!-- H1: SOLO keyword SEO — pequeño, para Google -->
      <h1 class="font-dm font-500 text-slate-500 text-[0.78rem] sm:text-[0.85rem]
                 tracking-[0.12em] uppercase leading-none mb-4 fade-up"
          style="animation-delay:0.08s">
        Solcellskalkylator för villa — beräkna solceller tak 2026
      </h1>

      <!-- EMOTIONAL HEADLINE — grande, para el cerebro (Klaric) — fuera del H1 -->
      <p class="font-syne font-800 text-white leading-[1.08] mb-5
                text-[2.2rem] sm:text-[2.9rem] lg:text-[3.5rem]
                fade-up" style="animation-delay:0.14s" aria-hidden="false">
        Betalar du för<br class="hidden sm:block" />
        <span class="text-solar-amber">mycket för el?</span>
      </p>

      <!-- SUBHEADLINE — integrates secondary keywords naturally -->
      <p class="font-dm text-slate-300 text-[1.05rem] sm:text-xl leading-relaxed mb-7 max-w-[580px]
                fade-up" style="animation-delay:0.2s">
        Se exakt hur mycket <strong class="text-white">du kan spara med solceller på tak</strong>
        — beräkna ditt pris, återbetalningstid och Grön Teknik-avdrag på 30 sekunder.
      </p>

      <!-- 30-SECOND BADGE — key CRO micro-commitment -->
      <div class="flex flex-wrap items-center gap-4 mb-8 fade-up" style="animation-delay:0.28s">
        <div class="inline-flex items-center gap-2.5 px-4 py-2.5 rounded-xl
                    bg-solar-amber-muted border border-solar-amber/40 text-solar-amber font-syne font-700 text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
          Det tar bara 30 sekunder
        </div>
        <div class="inline-flex items-center gap-2 text-sm text-slate-400 font-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-solar-green" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          100% Gratis &amp; Ej bindande
        </div>
      </div>

      <!-- CTA ARROW TO CALCULATOR -->
      <a href="#kalkylator"
         class="inline-flex items-center gap-3 font-syne font-700 text-[1.05rem]
                bg-amber-gradient text-black px-7 py-4 rounded-xl
                shadow-amber-glow cta-pulse hover:scale-[1.02] active:scale-[0.98]
                transition-transform duration-150 fade-up"
         style="animation-delay:0.36s">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
        </svg>
        Beräkna min besparing gratis
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>

      <!-- SOCIAL PROOF ROW -->
      <div class="flex flex-wrap items-center gap-5 mt-7 text-xs text-slate-500 fade-up" style="animation-delay:0.44s">
        <span class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-solar-green" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          Data från Skatteverket &amp; Svenska Kraftnät
        </span>
        <span class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-solar-green" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          Grön Teknik-avdraget inräknat
        </span>
        <span class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-solar-green" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          Uppdaterad 1 jan 2026
        </span>
      </div>

    </div>
  </div>

  <!-- DOWN ARROW -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 text-navy-500 animate-bounce hidden md:block"
       aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6 9 12 15 18 9"/>
    </svg>
  </div>

</section>
