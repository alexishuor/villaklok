---
interface Props {
  page?: 'home' | 'calculator';
}
const { page = 'home' } = Astro.props;

const calcBase = page === 'calculator' ? '' : '/solcellskalkylator';
---

<!-- ── AD DISCLOSURE ── -->
<div
  class="w-full bg-navy-900 border-b border-navy-700/60 text-center py-2 px-4
         text-[11px] tracking-[2px] uppercase text-slate-600"
  role="note"
>
  ANNONS: Inlägget innehåller annonslänkar via Adtraction för solcellsleverantörer i Sverige.
</div>

<!-- ── MOBILE BACKDROP (tap outside to close) ── -->
<div id="nav-backdrop" class="mobile-nav-backdrop" aria-hidden="true"></div>

<!-- ── STICKY HEADER ── -->
<header
  class="sticky top-0 z-50 bg-navy-900/95 backdrop-blur-md border-b border-navy-700/70"
  role="banner"
>
  <div class="max-w-6xl mx-auto px-5 h-[62px] flex items-center justify-between gap-4">

    <!-- LOGO -->
    <a
      href="/"
      class="flex items-center gap-2 flex-shrink-0 group"
      aria-label="Villaklok — startsida"
    >
      <svg viewBox="0 0 32 32" class="w-7 h-7 sun-spin origin-center flex-shrink-0"
           aria-hidden="true" focusable="false">
        <circle cx="16" cy="16" r="5.5" fill="#F59E0B"/>
        <g stroke="#F59E0B" stroke-width="2" stroke-linecap="round" opacity="0.65">
          <line x1="16" y1="2"    x2="16" y2="7"    />
          <line x1="16" y1="25"   x2="16" y2="30"   />
          <line x1="2"  y1="16"   x2="7"  y2="16"   />
          <line x1="25" y1="16"   x2="30" y2="16"   />
          <line x1="6.2"  y1="6.2"   x2="9.5"  y2="9.5"  />
          <line x1="22.5" y1="22.5"  x2="25.8" y2="25.8" />
          <line x1="25.8" y1="6.2"   x2="22.5" y2="9.5"  />
          <line x1="9.5"  y1="22.5"  x2="6.2"  y2="25.8" />
        </g>
      </svg>
      <span class="font-syne font-800 text-[1.1rem] text-white tracking-tight
                   group-hover:text-solar-amber transition-colors duration-200 leading-none">
        VILLA<span class="text-solar-amber" style="font-weight:300">KLOK</span>
      </span>
    </a>

    <!-- DESKTOP NAV LINKS — only shown on md+ via Tailwind -->
    <nav
      class="hidden md:flex items-center gap-7 flex-1 justify-center"
      aria-label="Primär navigation"
    >
      {page === 'home' && (
        <a href="/"
           class="font-dm font-600 text-[0.87rem] text-solar-amber
                  py-1 border-b-2 border-solar-amber/50
                  transition-all duration-150">Hem</a>
      )}
      <a href={`${calcBase}#kalkylator`}
         class="font-dm font-600 text-[0.87rem] text-slate-400 hover:text-white
                py-1 border-b-2 border-transparent hover:border-solar-amber/50
                transition-all duration-150">Kalkylator</a>
      <a href={`${calcBase}#info`}
         class="font-dm font-600 text-[0.87rem] text-slate-400 hover:text-white
                py-1 border-b-2 border-transparent hover:border-solar-amber/50
                transition-all duration-150">Om kalkylatorn</a>
      <a href={`${calcBase}#analys`}
         class="font-dm font-600 text-[0.87rem] text-slate-400 hover:text-white
                py-1 border-b-2 border-transparent hover:border-solar-amber/50
                transition-all duration-150">Marknadsanalys</a>
      <a href={`${calcBase}#faq`}
         class="font-dm font-600 text-[0.87rem] text-slate-400 hover:text-white
                py-1 border-b-2 border-transparent hover:border-solar-amber/50
                transition-all duration-150">FAQ</a>
    </nav>

    <!-- DESKTOP CTA — only shown on md+ -->
    <a
      href={`${calcBase || '/solcellskalkylator'}`}
      class="hidden md:inline-flex items-center gap-2 flex-shrink-0
             bg-solar-amber hover:bg-solar-amber-light
             text-black font-syne font-700 text-[0.82rem]
             px-4 py-2.5 rounded-lg transition-colors duration-150"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2.5"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
      </svg>
      Beräkna nu
    </a>

    <!-- HAMBURGER BUTTON — only shown on mobile (<md) -->
    <button
      id="nav-toggle"
      class="md:hidden relative z-[102]
             flex flex-col justify-center items-center gap-[5px]
             w-10 h-10 rounded-lg border border-navy-600 bg-navy-800
             hover:border-solar-amber/50 hover:bg-navy-700
             transition-colors duration-200"
      aria-label="Öppna navigationsmenyn"
      aria-expanded="false"
      aria-controls="mobile-nav-menu"
    >
      <span id="ham-1" class="block w-[18px] h-[2px] bg-slate-300 rounded transition-all duration-300 origin-center"></span>
      <span id="ham-2" class="block w-[18px] h-[2px] bg-slate-300 rounded transition-all duration-300"></span>
      <span id="ham-3" class="block w-[18px] h-[2px] bg-slate-300 rounded transition-all duration-300 origin-center"></span>
    </button>

  </div>
</header>

<!-- ── MOBILE NAV DRAWER ── -->
<div id="mobile-nav-menu" class="mobile-nav" role="dialog" aria-modal="true" aria-label="Navigationsmenyn" aria-hidden="true">

  <!-- DRAWER HEADER: logo + X close button -->
  <div class="drawer-header">
    <!-- Logo group -->
    <div class="drawer-logo">
      <svg viewBox="0 0 32 32" width="22" height="22" aria-hidden="true">
        <circle cx="16" cy="16" r="5.5" fill="#F59E0B"/>
        <g stroke="#F59E0B" stroke-width="2" stroke-linecap="round" opacity="0.7">
          <line x1="16" y1="2"   x2="16" y2="7"  />
          <line x1="16" y1="25"  x2="16" y2="30" />
          <line x1="2"  y1="16"  x2="7"  y2="16" />
          <line x1="25" y1="16"  x2="30" y2="16" />
          <line x1="6.5"  y1="6.5"   x2="9.5"  y2="9.5"  />
          <line x1="22.5" y1="22.5"  x2="25.5" y2="25.5" />
          <line x1="25.5" y1="6.5"   x2="22.5" y2="9.5"  />
          <line x1="9.5"  y1="22.5"  x2="6.5"  y2="25.5" />
        </g>
      </svg>
      <span class="drawer-logo-text">VILLA<span>KLOK</span></span>
    </div>
    <!-- X close button -->
    <button id="drawer-close" class="drawer-close-btn" aria-label="Stäng meny">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2.5"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6"  x2="6"  y2="18"/>
        <line x1="6"  y1="6"  x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- DIVIDER -->
  <div class="drawer-divider"></div>

  <!-- NAV LINKS -->
  <nav class="drawer-nav" aria-label="Mobilmeny">
    <a href={`${calcBase}#kalkylator`} class="drawer-link">
      <span class="drawer-link-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
        </svg>
      </span>
      <span>Kalkylator</span>
      <svg class="drawer-link-arrow" xmlns="http://www.w3.org/2000/svg" width="14" height="14"
           viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </a>

    <a href={`${calcBase}#info`} class="drawer-link">
      <span class="drawer-link-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      </span>
      <span>Om kalkylatorn</span>
      <svg class="drawer-link-arrow" xmlns="http://www.w3.org/2000/svg" width="14" height="14"
           viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </a>

    <a href={`${calcBase}#analys`} class="drawer-link">
      <span class="drawer-link-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="20" x2="18" y2="10"/>
          <line x1="12" y1="20" x2="12" y2="4"/>
          <line x1="6"  y1="20" x2="6"  y2="14"/>
        </svg>
      </span>
      <span>Marknadsanalys</span>
      <svg class="drawer-link-arrow" xmlns="http://www.w3.org/2000/svg" width="14" height="14"
           viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </a>

    <a href={`${calcBase}#faq`} class="drawer-link">
      <span class="drawer-link-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
          <line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
      </span>
      <span>FAQ</span>
      <svg class="drawer-link-arrow" xmlns="http://www.w3.org/2000/svg" width="14" height="14"
           viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </a>
  </nav>

  <!-- DIVIDER -->
  <div class="drawer-divider"></div>

  <!-- CTA -->
  <div class="drawer-cta-wrap">
    <a href={`${calcBase || '/solcellskalkylator'}`} class="drawer-cta-btn">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2.5"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
      </svg>
      Beräkna min besparing →
    </a>
    <p class="drawer-cta-sub">100% Gratis &amp; Ej bindande</p>
  </div>

</div>

<script>
  (() => {
    const toggle       = document.getElementById('nav-toggle');
    const drawer       = document.getElementById('mobile-nav-menu');
    const backdrop     = document.getElementById('nav-backdrop');
    const closeBtn     = document.getElementById('drawer-close');
    const ham1         = document.getElementById('ham-1');
    const ham2         = document.getElementById('ham-2');
    const ham3         = document.getElementById('ham-3');
    let   isOpen       = false;

    function openMenu() {
      isOpen = true;
      drawer?.classList.add('open');
      backdrop?.classList.add('open');
      toggle?.setAttribute('aria-expanded', 'true');
      drawer?.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      // Hamburger → X
      if (ham1) { ham1.style.transform = 'translateY(7px) rotate(45deg)';  ham1.style.background = '#F59E0B'; }
      if (ham2) { ham2.style.opacity = '0'; ham2.style.transform = 'scaleX(0)'; }
      if (ham3) { ham3.style.transform = 'translateY(-7px) rotate(-45deg)'; ham3.style.background = '#F59E0B'; }
    }

    function closeMenu() {
      isOpen = false;
      drawer?.classList.remove('open');
      backdrop?.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
      drawer?.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      // X → Hamburger
      if (ham1) { ham1.style.transform = ''; ham1.style.background = ''; }
      if (ham2) { ham2.style.opacity = ''; ham2.style.transform = ''; }
      if (ham3) { ham3.style.transform = ''; ham3.style.background = ''; }
    }

    toggle?.addEventListener('click',    () => isOpen ? closeMenu() : openMenu());
    closeBtn?.addEventListener('click',  closeMenu);
    backdrop?.addEventListener('click',  closeMenu);
    document.addEventListener('keydown', e => { if (e.key === 'Escape' && isOpen) closeMenu(); });

    // Close on any drawer link click
    drawer?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));

    // ── Smooth scroll for ALL anchor links ──
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function(e) {
        const href = this.getAttribute('href');
        if (href && href.length > 1) {
          const target = document.querySelector(href);
          if (target) {
            e.preventDefault();
            setTimeout(() => target.scrollIntoView({ behavior: 'smooth', block: 'start' }), 60);
          }
        }
      });
    });
  })();
</script>
