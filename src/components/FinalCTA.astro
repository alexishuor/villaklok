---
---
<section class="final-cta py-16 md:py-20 px-5 bg-navy-950 border-t border-navy-700 relative overflow-hidden">

  <!-- AMBIENT GLOWS -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px]"
         style="background: radial-gradient(ellipse at top, rgba(245,158,11,0.07) 0%, transparent 70%)">
    </div>
    <div class="absolute bottom-0 right-0 w-[400px] h-[400px]"
         style="background: radial-gradient(circle at bottom right, rgba(16,185,129,0.05) 0%, transparent 70%)">
    </div>
  </div>

  <div class="relative z-10 max-w-2xl mx-auto text-center">

    <!-- BADGE -->
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-navy-800 border border-navy-600
                text-xs font-600 text-solar-amber tracking-widest uppercase mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
      Säkra ditt pris nu
    </div>

    <!-- HEADLINE -->
    <h2 class="font-syne font-800 text-white text-3xl sm:text-4xl leading-tight mb-4">
      Priserna för 2026
      <span class="text-solar-amber">rör sig snabbt.</span>
    </h2>

    <!-- SUBTEXT -->
    <p class="font-dm text-slate-400 text-base sm:text-lg leading-relaxed mb-3 max-w-xl mx-auto">
      Jämför 3 certifierade installatörer och få det
      <strong class="text-white">garanterat lägsta priset</strong> för din villa.
      Det är gratis och tar 2 minuter.
    </p>

    <!-- LOSS AVERSION LINE -->
    <p class="font-dm text-red-400 text-sm font-600 mb-8">
      ⚠️ Varje månad du väntar är ännu en elräkning du betalar i onödan.
    </p>

    <!-- MAIN CTA BUTTON -->
    <a
      href="TU_LINK_DE_ADTRACTION"
      rel="sponsored noopener noreferrer"
      class="inline-flex items-center justify-center gap-3 w-full sm:w-auto
             py-4 sm:py-5 px-6 sm:px-10 rounded-xl
             font-syne font-800 text-lg sm:text-xl text-black
             bg-amber-gradient shadow-amber-glow-lg cta-pulse
             hover:scale-[1.02] active:scale-[0.98] transition-transform duration-150 mb-5"
      aria-label="Se mitt exakta pris via Hemsol"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
      </svg>
      SE MITT EXAKTA PRIS IDAG →
    </a>

    <!-- TRUST BADGES ROW -->
    <div class="flex flex-wrap items-center justify-center gap-x-7 gap-y-3 text-sm text-slate-500 font-600">
      <span class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-solar-green" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        100% Gratis &amp; Ej bindande
      </span>
      <span class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-solar-green" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        Endast certifierade bolag
      </span>
      <span class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-solar-green" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        Svar inom 24h
      </span>
    </div>

  </div>
</section>
